// роботы
..robot1
<- concept_mobile_robot;
<~ concept_stopped;
<|~ concept_box_loaded;;
nrel_location ~> (..robot1 => ..pointA);;

..robot2
<- concept_mobile_robot;
<~ concept_stopped;
<|~ concept_box_loaded;;
nrel_location ~> (..robot2 => ..pointA);;

..robot3
