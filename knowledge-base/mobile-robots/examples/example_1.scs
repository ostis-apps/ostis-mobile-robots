// маршрут
@route_example_1 = [*
    -> rrel_start_point: ..pointA;;
    -> rrel_end_point: ..pointB;;

    ..pointA => nrel_next_point: ..point1;;
    ..point1 => nrel_next_point: ..point2;;
    ..point2 => nrel_next_point: ..point3;;
    ..point3 => nrel_next_point: ..point4;;
    ..point4 => nrel_next_point: ..pointB;;
    ..pointB => nrel_next_point: ..point5;;
    ..point5 => nrel_next_point: ..point6;;
    ..point6 => nrel_next_point: ..point7;;
    ..point7 => nrel_next_point: ..pointA;;
*];;
@route_example_1 <- concept_route;;

// коробки
..box1
<- concept_box;;
nrel_location ~> (..box1 => ..pointA);;

..box2
<- concept_box;;
nrel_location ~> (..box2 => ..pointA);;

..box3
<- concept_box;;
nrel_location ~> (..box3 => ..pointA);;

